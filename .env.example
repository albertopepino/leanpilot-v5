# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# For production on Hetzner:
# DATABASE_URL="postgresql://leanpilot:CHANGE_ME@localhost:5432/leanpilot?schema=public"

# JWT
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_EXPIRATION="24h"
JWT_REFRESH_EXPIRATION="7d"

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000
API_URL="http://localhost:3001"

# Email (SMTP) — leave empty to log emails instead of sending
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@leanpilot.me"

# Frontend URL (for password reset links)
FRONTEND_URL="http://localhost:3000"

# Optional: Hetzner deploy
# HETZNER_HOST=""
# HETZNER_USER="root"
# DOMAIN="leanpilot.me"
