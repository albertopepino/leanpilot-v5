# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# For production on Hetzner:
# DATABASE_URL="postgresql://leanpilot:CHANGE_ME@localhost:5432/leanpilot?schema=public"

# JWT
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_EXPIRATION="24h"
JWT_REFRESH_EXPIRATION="7d"

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000
API_URL="http://localhost:3001"

# Optional: Hetzner deploy
# HETZNER_HOST=""
# HETZNER_USER="root"
# DOMAIN="leanpilot.me"
