generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== HIERARCHY: Corporate → Site → User =====

model Corporate {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites Site[]
  users User[]

  @@map("corporates")
}

model Site {
  id          String   @id @default(cuid())
  corporateId String
  name        String
  slug        String
  location    String?
  timezone    String   @default("Europe/Rome")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storageUsedBytes BigInt @default(0)

  corporate    Corporate          @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  users        User[]
  workstations Workstation[]
  orders       ProductionOrder[]
  reasonCodes  ReasonCode[]
  shifts       ShiftDefinition[]
  gembaWalks   GembaWalk[]
  fiveSAudits  FiveSAudit[]
  kaizenIdeas  KaizenIdea[]
  qualityTemplates QualityTemplate[]
  qualityInspections QualityInspection[]
  ncrs             NonConformanceReport[]
  reportTemplate   ReportTemplate?

  @@unique([corporateId, slug])
  @@map("sites")
}

// ===== AUTH & USERS =====
// Role values: corporate_admin | site_admin | manager | operator | viewer

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  role        String    @default("viewer")
  siteId      String
  corporateId String
  isActive    Boolean   @default(true)
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site      Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  corporate Corporate @relation(fields: [corporateId], references: [id], onDelete: Cascade)

  productionRuns     ProductionRun[]
  workstationEvents  WorkstationEvent[]
  gembaWalks         GembaWalk[]        @relation("GembaWalker")
  gembaObservations  GembaObservation[]
  fiveSAudits        FiveSAudit[]
  kaizenIdeas        KaizenIdea[]       @relation("KaizenSubmitter")
  kaizenReviews      KaizenIdea[]       @relation("KaizenReviewer")
  qualityTemplates   QualityTemplate[]
  qualityInspections QualityInspection[]
  ncrsReported       NonConformanceReport[] @relation("NcrReporter")
  ncrsVerified       NonConformanceReport[] @relation("NcrVerifier")
  refreshTokens      RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ===== AUDIT LOG (GDPR Art. 30/32, ISO 9001 Clause 7.5) =====

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String   // create, update, delete, login, login_failed, logout, export
  entityType String   // user, inspection, ncr, audit_5s, kaizen, gemba, order, run, file
  entityId   String?
  metadata   String?  // JSON: before/after diff, extra context
  ipAddress  String?
  userAgent  String?
  result     String   @default("success") // success, failure
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ===== PRODUCTION: Shop Floor =====

model Workstation {
  id     String @id @default(cuid())
  siteId String
  name   String
  type   String @default("machine") // machine | line | manual
  area   String @default("")
  code   String @default("")        // short code for display, e.g. "CNC-01"
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site            Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  phases          ProductionOrderPhase[]
  productionRuns  ProductionRun[]
  events          WorkstationEvent[]
  qualityInspections QualityInspection[]
  ncrs            NonConformanceReport[]

  @@unique([siteId, code])
  @@map("workstations")
}

// Configurable reason codes per site, per category
// category: breakdown | changeover | quality | idle | maintenance | planned_stop | scrap
model ReasonCode {
  id       String @id @default(cuid())
  siteId   String
  category String // which status or scrap this reason applies to
  code     String // short code, e.g. "MECH"
  label    String // display name, e.g. "Mechanical failure"
  color    String @default("#gray")
  sortOrder Int   @default(0)
  isActive Boolean @default(true)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, category, code])
  @@map("reason_codes")
}

model ShiftDefinition {
  id        String @id @default(cuid())
  siteId    String
  name      String   // "Morning", "Afternoon", "Night"
  startTime String   // "06:00"
  endTime   String   // "14:00"
  days      String   // JSON: ["mon","tue","wed","thu","fri"]
  isActive  Boolean  @default(true)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("shift_definitions")
}

// ===== PRODUCTION ORDER =====

model ProductionOrder {
  id             String    @id @default(cuid())
  siteId         String
  poNumber       String
  productName    String
  targetQuantity Int
  unit           String    @default("pcs")
  dueDate        DateTime?
  priority       String    @default("normal") // normal | high | urgent
  status         String    @default("released") // draft | released | in_progress | completed | closed
  source         String    @default("manual") // manual | excel | erp
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  site   Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  phases ProductionOrderPhase[]

  @@unique([siteId, poNumber])
  @@map("production_orders")
}

model ProductionOrderPhase {
  id               String @id @default(cuid())
  orderId          String
  sequence         Int    // 10, 20, 30...
  name             String // "Cutting", "Bending", "Welding"
  workstationId    String // planned workstation
  cycleTimeSeconds Int    // theoretical cycle time for OEE Performance
  status           String @default("pending") // pending | in_progress | completed

  order       ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  workstation Workstation     @relation(fields: [workstationId], references: [id])
  runs        ProductionRun[]

  @@unique([orderId, sequence])
  @@map("production_order_phases")
}

// ===== PRODUCTION RUN (operator executing a phase on a workstation) =====

model ProductionRun {
  id               String    @id @default(cuid())
  phaseId          String
  workstationId    String    // actual workstation (may differ from planned)
  operatorId       String
  shiftDate        String    // "2026-03-23"
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  producedQuantity Int       @default(0)
  scrapQuantity    Int       @default(0)
  status           String    @default("active") // active | completed

  phase       ProductionOrderPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  workstation Workstation          @relation(fields: [workstationId], references: [id])
  operator    User                 @relation(fields: [operatorId], references: [id])
  events      WorkstationEvent[]

  @@map("production_runs")
}

// ===== WORKSTATION EVENT (append-only — THE source of truth) =====
// eventType: status_change | flag | shift_start | shift_end | po_start | po_end
// status (for status_change): running | breakdown | changeover | quality_hold | idle | maintenance | planned_stop

model WorkstationEvent {
  id              String   @id @default(cuid())
  workstationId   String
  productionRunId String?
  operatorId      String
  eventType       String   // status_change | flag | shift_start | shift_end | po_start | po_end
  status          String?  // running | breakdown | changeover | quality_hold | idle | maintenance | planned_stop
  reasonCode      String?  // code from ReasonCode table
  notes           String?
  timestamp       DateTime @default(now()) // when it happened (from tablet)
  syncedAt        DateTime @default(now()) // when server received it

  workstation   Workstation    @relation(fields: [workstationId], references: [id], onDelete: Cascade)
  productionRun ProductionRun? @relation(fields: [productionRunId], references: [id])
  operator      User           @relation(fields: [operatorId], references: [id])

  @@index([workstationId, timestamp])
  @@map("workstation_events")
}

// ===== GEMBA WALK =====

model GembaWalk {
  id        String    @id @default(cuid())
  siteId    String
  walkerId  String
  date      String    // "2026-03-23"
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  status    String    @default("in_progress") // in_progress | completed

  site         Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  walker       User               @relation("GembaWalker", fields: [walkerId], references: [id])
  observations GembaObservation[]

  @@map("gemba_walks")
}

// wasteCategory: waiting | overproduction | inventory | motion | transportation | over_processing | defect | talent
model GembaObservation {
  id            String  @id @default(cuid())
  walkId        String
  observerId    String
  workstationId String? // optional — where was this observed
  wasteCategory String  // one of the 8 wastes
  severity      String  @default("medium") // low | medium | high
  description   String
  photoUrl      String?
  operatorQuote String? // what the operator said
  status        String  @default("open") // open | investigating | addressed | closed
  escalatedTo   String? // improvement_project | kaizen | action_item | none
  createdAt     DateTime @default(now())

  walk     GembaWalk @relation(fields: [walkId], references: [id], onDelete: Cascade)
  observer User      @relation(fields: [observerId], references: [id])
  kaizenIdea KaizenIdea?

  @@map("gemba_observations")
}

// ===== 5S / 6S AUDIT =====

model FiveSAudit {
  id          String    @id @default(cuid())
  siteId      String
  area        String
  auditorId   String
  status      String    @default("draft") // draft | completed
  totalScore  Int       @default(0)
  maxScore    Int       @default(30) // 6 categories × 5 max
  percentage  Float     @default(0)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  site    Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  auditor User        @relation(fields: [auditorId], references: [id])
  scores  FiveSScore[]

  @@index([siteId])
  @@map("five_s_audits")
}

model FiveSScore {
  id       String  @id @default(cuid())
  auditId  String
  category String  // sort | set_in_order | shine | standardize | sustain | safety
  score    Int     @default(0) // 0-5
  notes    String?
  photoUrl String?

  audit FiveSAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, category])
  @@map("five_s_scores")
}

// ===== KAIZEN BOARD =====

model KaizenIdea {
  id                 String    @id @default(cuid())
  siteId             String
  submittedById      String
  title              String
  problem            String
  proposedSolution   String?
  expectedImpact     String    @default("medium") // low | medium | high
  area               String?
  status             String    @default("submitted") // submitted | under_review | approved | in_progress | completed | rejected
  reviewedById       String?
  reviewNotes        String?
  implementedAt      DateTime?
  result             String?
  photoUrl           String?
  gembaObservationId String?   @unique
  createdAt          DateTime  @default(now())

  site              Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  submittedBy       User              @relation("KaizenSubmitter", fields: [submittedById], references: [id])
  reviewedBy        User?             @relation("KaizenReviewer", fields: [reviewedById], references: [id])
  gembaObservation  GembaObservation? @relation(fields: [gembaObservationId], references: [id])

  @@index([siteId])
  @@index([status])
  @@map("kaizen_ideas")
}

// ===== QUALITY MODULE =====

model QualityTemplate {
  id          String  @id @default(cuid())
  siteId      String
  name        String
  productName String?
  phase       String?
  createdById String
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  site        Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy   User                @relation(fields: [createdById], references: [id])
  checkpoints QualityCheckpoint[]
  inspections QualityInspection[]

  @@index([siteId])
  @@map("quality_templates")
}

model QualityCheckpoint {
  id              String  @id @default(cuid())
  templateId      String
  sequence        Int
  description     String
  measurementType String  @default("pass_fail") // pass_fail | measurement | visual
  unit            String? // mm, kg, etc.
  lowerLimit      Float?
  upperLimit      Float?
  targetValue     Float?
  isRequired      Boolean @default(true)

  template QualityTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  QualityResult[]

  @@unique([templateId, sequence])
  @@map("quality_checkpoints")
}

model QualityInspection {
  id            String    @id @default(cuid())
  siteId        String
  templateId    String
  orderId       String?
  phaseId       String?
  workstationId String
  inspectorId   String
  status        String    @default("in_progress") // in_progress | passed | failed | conditional
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  site        Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  template    QualityTemplate   @relation(fields: [templateId], references: [id])
  workstation Workstation       @relation(fields: [workstationId], references: [id])
  inspector   User              @relation(fields: [inspectorId], references: [id])
  results     QualityResult[]

  @@index([siteId])
  @@index([templateId])
  @@map("quality_inspections")
}

model QualityResult {
  id           String  @id @default(cuid())
  inspectionId String
  checkpointId String
  value        String  // measurement value or "pass"/"fail"
  passed       Boolean
  notes        String?
  photoUrl     String?

  inspection QualityInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checkpoint QualityCheckpoint @relation(fields: [checkpointId], references: [id])

  @@unique([inspectionId, checkpointId])
  @@map("quality_results")
}

model NonConformanceReport {
  id               String    @id @default(cuid())
  siteId           String
  reporterId       String
  orderId          String?
  workstationId    String?
  title            String    @default("")
  severity         String    @default("minor") // minor | major | critical
  description      String
  defectQuantity   Int       @default(0)
  rootCause        String?
  containmentAction String?
  correctiveAction  String?
  preventiveAction  String?
  verifiedById     String?
  status           String    @default("open") // open | containment | investigation | corrective | verification | closed
  closedAt         DateTime?
  createdAt        DateTime  @default(now())

  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reporter    User         @relation("NcrReporter", fields: [reporterId], references: [id])
  verifiedBy  User?        @relation("NcrVerifier", fields: [verifiedById], references: [id])
  workstation Workstation? @relation(fields: [workstationId], references: [id])
  attachments NcrAttachment[]

  @@index([siteId])
  @@index([status])
  @@map("non_conformance_reports")
}

model NcrAttachment {
  id           String   @id @default(cuid())
  ncrId        String
  fileName     String
  fileUrl      String
  uploadedById String
  createdAt    DateTime @default(now())

  ncr NonConformanceReport @relation(fields: [ncrId], references: [id], onDelete: Cascade)

  @@map("ncr_attachments")
}

// ===== REPORTS =====

model ReportTemplate {
  id          String   @id @default(cuid())
  siteId      String
  logoUrl     String?
  companyName String
  headerText  String?
  accentColor String   @default("#2563eb")
  footerText  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId])
  @@map("report_templates")
}
