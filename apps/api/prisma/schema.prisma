generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== HIERARCHY: Corporate → Site → User =====

model Corporate {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites Site[]
  users User[]

  @@map("corporates")
}

model Site {
  id          String   @id @default(cuid())
  corporateId String
  name        String
  slug        String
  location    String?
  timezone    String   @default("Europe/Rome")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storageUsedBytes BigInt @default(0)

  corporate          Corporate              @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  users              User[]
  workstations       Workstation[]
  orders             ProductionOrder[]
  reasonCodes        ReasonCode[]
  shifts             ShiftDefinition[]
  gembaWalks         GembaWalk[]
  fiveSAudits        FiveSAudit[]
  kaizenIdeas        KaizenIdea[]
  qualityTemplates   QualityTemplate[]
  qualityInspections QualityInspection[]
  ncrs               NonConformanceReport[]
  reportTemplate     ReportTemplate?
  documents          Document[]
  maintenancePlans   MaintenancePlan[]
  maintenanceLogs    MaintenanceLog[]
  ciltChecks         CiltCheck[]
  fiveWhyAnalyses    FiveWhyAnalysis[]
  ishikawaAnalyses   IshikawaAnalysis[]
  eightDReports      EightDReport[]
  safetyIncidents    SafetyIncident[]
  actions            Action[]
  notifications      Notification[]
  tierMeetings       TierMeeting[]
  a3Reports          A3Report[]
  skills             Skill[]
  smedAnalyses       SmedAnalysis[]
  toolConfigs        SiteToolConfig[]
  customRoles        CustomRole[]
  escalationRules    EscalationRule[]
  capas              CorrectiveAction[]

  @@unique([corporateId, slug])
  @@map("sites")
}

// ===== PERMISSION MATRIX =====

model CustomRole {
  id          String   @id @default(cuid())
  siteId      String?
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site        Site?            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]

  @@unique([siteId, name])
  @@map("custom_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  featureGroup String // production, shift_management, continuous_improvement, quality, problem_solving, safety, maintenance, people
  level        String // none, view, participate, manage

  role CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, featureGroup])
  @@map("role_permissions")
}

// ===== AUTH & USERS =====
// System roles: corporate_admin | site_admin | viewer
// Custom roles: assigned via customRoleId with permission matrix

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  role          String     @default("viewer") // system role: corporate_admin | site_admin | viewer (or legacy)
  customRoleId  String?
  siteId        String
  corporateId   String
  isActive      Boolean    @default(true)
  lastLogin     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  corporate  Corporate   @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id])

  productionRuns           ProductionRun[]
  workstationEvents        WorkstationEvent[]
  gembaWalks               GembaWalk[]            @relation("GembaWalker")
  gembaObservations        GembaObservation[]
  fiveSAudits              FiveSAudit[]
  kaizenIdeas              KaizenIdea[]           @relation("KaizenSubmitter")
  kaizenReviews            KaizenIdea[]           @relation("KaizenReviewer")
  qualityTemplates         QualityTemplate[]
  qualityInspections       QualityInspection[]
  ncrsReported             NonConformanceReport[] @relation("NcrReporter")
  ncrsVerified             NonConformanceReport[] @relation("NcrVerifier")
  refreshTokens            RefreshToken[]
  documentsCreated         Document[]             @relation("DocumentCreator")
  documentsApproved        Document[]             @relation("DocumentApprover")
  documentRevisions        DocumentRevision[]     @relation("RevisionUploader")
  maintenancePlansAssigned MaintenancePlan[]      @relation("PlanAssignee")
  maintenanceLogsPerformed MaintenanceLog[]       @relation("MaintenancePerformer")
  ciltChecksPerformed      CiltCheck[]
  fiveWhyAnalyses          FiveWhyAnalysis[]      @relation("FiveWhyAnalyst")
  ishikawaAnalyses         IshikawaAnalysis[]     @relation("IshikawaAnalyst")
  eightDReportsLead        EightDReport[]         @relation("EightDLead")
  safetyReported           SafetyIncident[]       @relation("SafetyReporter")
  safetyInvestigated       SafetyIncident[]       @relation("SafetyInvestigator")
  gembaAssignments         GembaObservation[]     @relation("GembaAssignee")
  actionsAssigned          Action[]               @relation("ActionAssignee")
  actionsCreated           Action[]               @relation("ActionCreator")
  notifications            Notification[]
  tierMeetingsLed          TierMeeting[]          @relation("TierMeetingLeader")
  a3ReportsOwned           A3Report[]             @relation("A3Owner")
  a3ReportsSponsored       A3Report[]             @relation("A3Sponsor")
  userSkills               UserSkill[]
  skillAssessments         UserSkill[]            @relation("SkillAssessor")
  smedAnalyses             SmedAnalysis[]         @relation("SmedAnalyst")
  capasAssigned            CorrectiveAction[]     @relation("CapaAssignee")
  capasCreated             CorrectiveAction[]     @relation("CapaCreator")
  capasVerified            CorrectiveAction[]     @relation("CapaVerifier")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ===== AUDIT LOG (GDPR Art. 30/32, ISO 9001 Clause 7.5) =====

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String // create, update, delete, login, login_failed, logout, export
  entityType String // user, inspection, ncr, audit_5s, kaizen, gemba, order, run, file
  entityId   String?
  metadata   String? // JSON: before/after diff, extra context
  ipAddress  String?
  userAgent  String?
  result     String   @default("success") // success, failure
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ===== PRODUCTION: Shop Floor =====

model Workstation {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  type      String   @default("machine") // machine | line | manual
  area      String   @default("")
  code      String   @default("") // short code for display, e.g. "CNC-01"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Asset management fields (TPM / ISO 55001)
  serialNumber       String?
  manufacturer       String?
  modelNumber        String?
  acquisitionDate    DateTime?
  warrantyExpiry     DateTime?
  criticality        String    @default("B") // A=critical, B=important, C=general
  assetTag           String? // unique per site, for QR/barcode scan
  equipmentStatus    String    @default("operational") // operational | degraded | down | decommissioned
  photoUrl           String?
  plannedHoursPerDay Float     @default(8) // OEE: planned production hours per day (default 8h shift)

  // Parent-child tree: Line → Machines
  parentId String?
  parent   Workstation?  @relation("WorkstationTree", fields: [parentId], references: [id])
  children Workstation[] @relation("WorkstationTree")

  site               Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  phases             ProductionOrderPhase[]
  productionRuns     ProductionRun[]
  events             WorkstationEvent[]
  qualityInspections QualityInspection[]
  ncrs               NonConformanceReport[]
  maintenancePlans   MaintenancePlan[]
  maintenanceLogs    MaintenanceLog[]
  ciltChecks         CiltCheck[]
  safetyIncidents    SafetyIncident[]
  smedAnalyses       SmedAnalysis[]

  @@unique([siteId, code])
  @@map("workstations")
}

// Configurable reason codes per site, per category
// category: breakdown | changeover | quality | idle | maintenance | planned_stop | scrap
model ReasonCode {
  id        String  @id @default(cuid())
  siteId    String
  category  String // which status or scrap this reason applies to
  code      String // short code, e.g. "MECH"
  label     String // display name, e.g. "Mechanical failure"
  color     String  @default("#gray")
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, category, code])
  @@map("reason_codes")
}

model ShiftDefinition {
  id        String  @id @default(cuid())
  siteId    String
  name      String // "Morning", "Afternoon", "Night"
  startTime String // "06:00"
  endTime   String // "14:00"
  days      String // JSON: ["mon","tue","wed","thu","fri"]
  isActive  Boolean @default(true)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("shift_definitions")
}

// ===== PRODUCTION ORDER =====

model ProductionOrder {
  id             String    @id @default(cuid())
  siteId         String
  poNumber       String
  productName    String
  targetQuantity Int
  unit           String    @default("pcs")
  dueDate        DateTime?
  priority       String    @default("normal") // normal | high | urgent
  status         String    @default("released") // draft | released | in_progress | completed | closed
  source         String    @default("manual") // manual | excel | erp
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  site   Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  phases ProductionOrderPhase[]
  ncrs   NonConformanceReport[]

  @@unique([siteId, poNumber])
  @@map("production_orders")
}

model ProductionOrderPhase {
  id               String @id @default(cuid())
  orderId          String
  sequence         Int // 10, 20, 30...
  name             String // "Cutting", "Bending", "Welding"
  workstationId    String // planned workstation
  cycleTimeSeconds Int // theoretical cycle time for OEE Performance
  status           String @default("pending") // pending | in_progress | completed

  order       ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  workstation Workstation     @relation(fields: [workstationId], references: [id])
  runs        ProductionRun[]

  @@unique([orderId, sequence])
  @@map("production_order_phases")
}

// ===== PRODUCTION RUN (operator executing a phase on a workstation) =====

model ProductionRun {
  id               String    @id @default(cuid())
  phaseId          String
  workstationId    String // actual workstation (may differ from planned)
  operatorId       String
  shiftDate        String // "2026-03-23"
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  producedQuantity Int       @default(0)
  scrapQuantity    Int       @default(0)
  status           String    @default("active") // active | completed

  phase       ProductionOrderPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  workstation Workstation          @relation(fields: [workstationId], references: [id])
  operator    User                 @relation(fields: [operatorId], references: [id])
  events      WorkstationEvent[]

  @@map("production_runs")
}

// ===== WORKSTATION EVENT (append-only — THE source of truth) =====
// eventType: status_change | flag | shift_start | shift_end | po_start | po_end
// status (for status_change): running | breakdown | changeover | quality_hold | idle | maintenance | planned_stop

model WorkstationEvent {
  id              String   @id @default(cuid())
  workstationId   String
  productionRunId String?
  operatorId      String
  eventType       String // status_change | flag | shift_start | shift_end | po_start | po_end
  status          String? // running | breakdown | changeover | quality_hold | idle | maintenance | planned_stop
  reasonCode      String? // code from ReasonCode table
  notes           String?
  timestamp       DateTime @default(now()) // when it happened (from tablet)
  syncedAt        DateTime @default(now()) // when server received it

  workstation   Workstation    @relation(fields: [workstationId], references: [id], onDelete: Cascade)
  productionRun ProductionRun? @relation(fields: [productionRunId], references: [id])
  operator      User           @relation(fields: [operatorId], references: [id])

  @@index([workstationId, timestamp])
  @@map("workstation_events")
}

// ===== GEMBA WALK =====

model GembaWalk {
  id        String    @id @default(cuid())
  siteId    String
  walkerId  String
  date      String // "2026-03-23"
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  status    String    @default("in_progress") // in_progress | completed

  site         Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  walker       User               @relation("GembaWalker", fields: [walkerId], references: [id])
  observations GembaObservation[]

  @@map("gemba_walks")
}

// wasteCategory: waiting | overproduction | inventory | motion | transportation | over_processing | defect | talent
model GembaObservation {
  id            String  @id @default(cuid())
  walkId        String
  observerId    String
  workstationId String? // optional — where was this observed
  wasteCategory String // one of the 8 wastes
  severity      String  @default("medium") // low | medium | high
  description   String
  photoUrl      String?
  operatorQuote String? // what the operator said
  status        String  @default("open") // open | investigating | addressed | closed
  escalatedTo   String? // improvement_project | kaizen | action_item | none

  // PDCA follow-up fields
  actionRequired String? // what needs to be done
  assignedToId   String? // relation to User
  dueDate        DateTime?
  completedAt    DateTime?

  createdAt DateTime @default(now())

  walk       GembaWalk   @relation(fields: [walkId], references: [id], onDelete: Cascade)
  observer   User        @relation(fields: [observerId], references: [id])
  assignedTo User?       @relation("GembaAssignee", fields: [assignedToId], references: [id])
  kaizenIdea KaizenIdea?

  @@map("gemba_observations")
}

// ===== 5S / 6S AUDIT =====

model FiveSAudit {
  id          String    @id @default(cuid())
  siteId      String
  area        String
  auditorId   String
  status      String    @default("draft") // draft | completed
  totalScore  Int       @default(0)
  maxScore    Int       @default(30) // 6 categories × 5 max
  percentage  Float     @default(0)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  site    Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  auditor User         @relation(fields: [auditorId], references: [id])
  scores  FiveSScore[]

  @@index([siteId])
  @@map("five_s_audits")
}

model FiveSScore {
  id       String  @id @default(cuid())
  auditId  String
  category String // sort | set_in_order | shine | standardize | sustain | safety
  score    Int     @default(0) // 0-5
  notes    String?
  photoUrl String?

  audit FiveSAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, category])
  @@map("five_s_scores")
}

// ===== KAIZEN BOARD =====

model KaizenIdea {
  id                 String    @id @default(cuid())
  siteId             String
  submittedById      String
  title              String
  problem            String
  proposedSolution   String?
  expectedImpact     String    @default("medium") // low | medium | high
  area               String?
  status             String    @default("submitted") // submitted | under_review | approved | in_progress | completed | rejected
  reviewedById       String?
  reviewNotes        String?
  implementedAt      DateTime?
  result             String?
  photoUrl           String?
  expectedSavings    Float? // estimated cost reduction in EUR
  actualSavings      Float? // verified savings after implementation
  costToImplement    Float? // cost to implement the improvement
  savingsType        String? // time | cost | quality | safety | productivity
  gembaObservationId String?   @unique
  createdAt          DateTime  @default(now())

  site             Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  submittedBy      User              @relation("KaizenSubmitter", fields: [submittedById], references: [id])
  reviewedBy       User?             @relation("KaizenReviewer", fields: [reviewedById], references: [id])
  gembaObservation GembaObservation? @relation(fields: [gembaObservationId], references: [id])

  @@index([siteId])
  @@index([status])
  @@map("kaizen_ideas")
}

// ===== QUALITY MODULE =====

model QualityTemplate {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  productName String?
  phase       String?
  createdById String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  site        Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy   User                @relation(fields: [createdById], references: [id])
  checkpoints QualityCheckpoint[]
  inspections QualityInspection[]

  @@index([siteId])
  @@map("quality_templates")
}

model QualityCheckpoint {
  id              String  @id @default(cuid())
  templateId      String
  sequence        Int
  description     String
  measurementType String  @default("pass_fail") // pass_fail | measurement | visual
  unit            String? // mm, kg, etc.
  lowerLimit      Float?
  upperLimit      Float?
  targetValue     Float?
  isRequired      Boolean @default(true)

  template QualityTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  QualityResult[]

  @@unique([templateId, sequence])
  @@map("quality_checkpoints")
}

model QualityInspection {
  id            String    @id @default(cuid())
  siteId        String
  templateId    String
  orderId       String?
  phaseId       String?
  workstationId String
  inspectorId   String
  status        String    @default("in_progress") // in_progress | passed | failed | conditional
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  template    QualityTemplate @relation(fields: [templateId], references: [id])
  workstation Workstation     @relation(fields: [workstationId], references: [id])
  inspector   User            @relation(fields: [inspectorId], references: [id])
  results     QualityResult[]

  @@index([siteId])
  @@index([templateId])
  @@map("quality_inspections")
}

model QualityResult {
  id           String  @id @default(cuid())
  inspectionId String
  checkpointId String
  value        String // measurement value or "pass"/"fail"
  passed       Boolean
  notes        String?
  photoUrl     String?

  inspection QualityInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checkpoint QualityCheckpoint @relation(fields: [checkpointId], references: [id])

  @@unique([inspectionId, checkpointId])
  @@map("quality_results")
}

model NonConformanceReport {
  id                String    @id @default(cuid())
  siteId            String
  reporterId        String
  orderId           String?
  workstationId     String?
  title             String    @default("")
  severity          String    @default("minor") // minor | major | critical
  description       String
  defectQuantity    Int       @default(0)
  rootCause         String?
  containmentAction String?
  correctiveAction  String?
  preventiveAction  String?
  verifiedById      String?
  status            String    @default("open") // open | containment | investigation | corrective | verification | closed
  closedAt          DateTime?
  createdAt         DateTime  @default(now())

  site        Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reporter    User             @relation("NcrReporter", fields: [reporterId], references: [id])
  verifiedBy  User?            @relation("NcrVerifier", fields: [verifiedById], references: [id])
  workstation Workstation?     @relation(fields: [workstationId], references: [id])
  order       ProductionOrder? @relation(fields: [orderId], references: [id])
  attachments NcrAttachment[]
  capas       CorrectiveAction[]

  @@index([siteId])
  @@index([status])
  @@map("non_conformance_reports")
}

model NcrAttachment {
  id           String   @id @default(cuid())
  ncrId        String
  fileName     String
  fileUrl      String
  uploadedById String
  createdAt    DateTime @default(now())

  ncr NonConformanceReport @relation(fields: [ncrId], references: [id], onDelete: Cascade)

  @@map("ncr_attachments")
}

// ===== CAPA (Corrective & Preventive Action) =====

model CorrectiveAction {
  id               String    @id @default(cuid())
  siteId           String
  capaNumber       String    // Auto-generated: CAPA-2026-001
  ncrId            String?
  incidentId       String?
  type             String    // corrective | preventive
  title            String
  description      String
  assigneeId       String
  createdById      String
  dueDate          DateTime
  priority         String    @default("medium") // low | medium | high | critical
  status           String    @default("open") // open | in_progress | implemented | verification | effective | closed | ineffective
  rootCause        String?
  actionTaken      String?
  implementedAt    DateTime?
  verificationMethod String?
  verificationDate DateTime?
  verifiedById     String?
  effectivenessCheck String? // description of how effectiveness was verified
  effectivenessDate DateTime?
  effectiveResult  String?   // effective | ineffective | partial
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  site        Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ncr         NonConformanceReport? @relation(fields: [ncrId], references: [id])
  assignee    User                  @relation("CapaAssignee", fields: [assigneeId], references: [id])
  createdBy   User                  @relation("CapaCreator", fields: [createdById], references: [id])
  verifiedBy  User?                 @relation("CapaVerifier", fields: [verifiedById], references: [id])

  @@unique([siteId, capaNumber])
  @@index([siteId, status])
  @@map("corrective_actions_capa")
}

// ===== REPORTS =====

model ReportTemplate {
  id          String   @id @default(cuid())
  siteId      String
  logoUrl     String?
  companyName String
  headerText  String?
  accentColor String   @default("#2563eb")
  footerText  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId])
  @@map("report_templates")
}

// ===== DOCUMENT MANAGEMENT (ISO 9001 Clause 7.5) =====

model Document {
  id             String    @id @default(cuid())
  siteId         String
  title          String
  description    String?
  category       String // policy, procedure, form, specification
  status         String    @default("draft") // draft, review, approved, obsolete
  currentVersion Int       @default(1)
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  site       Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("DocumentCreator", fields: [createdById], references: [id])
  approvedBy User?              @relation("DocumentApprover", fields: [approvedById], references: [id])
  revisions  DocumentRevision[]

  @@index([siteId])
  @@index([category, status])
  @@map("documents")
}

model DocumentRevision {
  id           String   @id @default(cuid())
  documentId   String
  version      Int
  fileUrl      String
  fileName     String
  fileSize     Int
  changeNotes  String?
  uploadedById String
  createdAt    DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("RevisionUploader", fields: [uploadedById], references: [id])

  @@unique([documentId, version])
  @@map("document_revisions")
}

// ===== EQUIPMENT & MAINTENANCE (TPM / ISO 55001) =====

model MaintenancePlan {
  id                String    @id @default(cuid())
  siteId            String
  workstationId     String
  name              String // "Weekly lubrication", "Annual calibration"
  type              String    @default("preventive") // preventive | predictive | condition_based | calibration
  frequencyDays     Int // repeat every N days
  frequencyHours    Int? // hour-based PMs (e.g., every 500 running hours)
  estimatedMinutes  Int?
  instructions      String?
  assignedToId      String?
  isActive          Boolean   @default(true)
  nextDueDate       DateTime
  lastCompletedDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  site        Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workstation Workstation      @relation(fields: [workstationId], references: [id], onDelete: Cascade)
  assignedTo  User?            @relation("PlanAssignee", fields: [assignedToId], references: [id])
  logs        MaintenanceLog[]

  @@index([siteId])
  @@index([nextDueDate])
  @@map("maintenance_plans")
}

model MaintenanceLog {
  id              String   @id @default(cuid())
  siteId          String
  workstationId   String
  planId          String? // null = corrective/unplanned
  type            String // preventive | corrective | emergency
  performedById   String
  description     String
  partsUsed       String? // JSON array of parts
  failureCode     String? // standardized failure code for Pareto
  durationMinutes Int? // labor time
  downtimeMinutes Int? // production time lost
  cost            Float?
  status          String   @default("completed") // completed | partial | deferred
  performedAt     DateTime @default(now())

  site           Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workstation    Workstation      @relation(fields: [workstationId], references: [id], onDelete: Cascade)
  plan           MaintenancePlan? @relation(fields: [planId], references: [id])
  performedBy    User             @relation("MaintenancePerformer", fields: [performedById], references: [id])
  ciltEscalation CiltCheck?

  @@index([siteId])
  @@index([workstationId, performedAt])
  @@map("maintenance_logs")
}

// TPM Pillar 1: Autonomous Maintenance — CILT (Clean, Inspect, Lubricate, Tighten)
model CiltCheck {
  id                     String   @id @default(cuid())
  siteId                 String
  workstationId          String
  operatorId             String
  date                   String // "2026-03-24"
  shift                  String? // "morning" | "afternoon" | "night"
  cleaningDone           Boolean  @default(false)
  cleaningNotes          String?
  inspectionDone         Boolean  @default(false)
  inspectionNotes        String?
  lubricationDone        Boolean  @default(false)
  lubricationNotes       String?
  tighteningDone         Boolean  @default(false)
  tighteningNotes        String?
  abnormalityFound       Boolean  @default(false)
  abnormalityDescription String?
  photoUrl               String?
  maintenanceLogId       String?  @unique // escalate to corrective maintenance
  createdAt              DateTime @default(now())

  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workstation    Workstation     @relation(fields: [workstationId], references: [id], onDelete: Cascade)
  operator       User            @relation(fields: [operatorId], references: [id])
  maintenanceLog MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id])

  @@index([siteId])
  @@index([workstationId, date])
  @@map("cilt_checks")
}

// ===== ROOT CAUSE ANALYSIS (5-Why, Fishbone/Ishikawa, 8D) =====

model FiveWhyAnalysis {
  id               String    @id @default(cuid())
  siteId           String
  title            String
  status           String    @default("open") // open | in_progress | completed | verified
  ncrId            String?
  incidentId       String?
  analystId        String
  rootCauseSummary String?
  categoryTag      String? // mechanical | electrical | procedural | human_error | material_defect | environmental | design | software
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  analyst       User           @relation("FiveWhyAnalyst", fields: [analystId], references: [id])
  steps         FiveWhyStep[]
  eightDReports EightDReport[] @relation("EightDFiveWhy")

  @@index([siteId])
  @@map("five_why_analyses")
}

model FiveWhyStep {
  id         String @id @default(cuid())
  analysisId String
  stepNumber Int // 1-5
  question   String
  answer     String

  analysis FiveWhyAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, stepNumber])
  @@map("five_why_steps")
}

model IshikawaAnalysis {
  id               String    @id @default(cuid())
  siteId           String
  title            String
  status           String    @default("open") // open | in_progress | completed | verified
  ncrId            String?
  incidentId       String?
  analystId        String
  rootCauseSummary String?
  categoryTag      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  site          Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  analyst       User            @relation("IshikawaAnalyst", fields: [analystId], references: [id])
  causes        IshikawaCause[]
  eightDReports EightDReport[]  @relation("EightDIshikawa")

  @@index([siteId])
  @@map("ishikawa_analyses")
}

model IshikawaCause {
  id          String  @id @default(cuid())
  analysisId  String
  category    String // man | machine | method | material | measurement | environment
  description String
  isRootCause Boolean @default(false)

  analysis IshikawaAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("ishikawa_causes")
}

model EightDReport {
  id           String  @id @default(cuid())
  siteId       String
  title        String
  ncrId        String?
  incidentId   String?
  status       String  @default("d0_initiated")
  // d0_initiated | d1_team | d2_problem | d3_containment | d4_root_cause | d5_corrective | d6_implemented | d7_prevention | d8_closed
  teamLeaderId String
  teamMembers  String? // JSON array of user IDs

  // D2: Problem Description
  d2ProblemDescription String?
  d2IsIsNot            String? // JSON: IS/IS NOT analysis

  // D3: Interim Containment
  d3ContainmentActions   String?
  d3ContainmentEffective Boolean?

  // D4: Root Cause
  d4FiveWhyId        String?
  d4IshikawaId       String?
  d4RootCauseSummary String?

  // D5-D6: Corrective Actions
  d5CorrectiveActions   String?
  d6ImplementationNotes String?

  // D7: Prevention
  d7SystemicChanges String?
  d7LessonsLearned  String?

  // D8: Closure
  d8ClosedAt         DateTime?
  d8CustomerResponse String?

  categoryTag String? // mechanical | electrical | procedural | human_error | material_defect | environmental

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site       Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  teamLeader User              @relation("EightDLead", fields: [teamLeaderId], references: [id])
  fiveWhy    FiveWhyAnalysis?  @relation("EightDFiveWhy", fields: [d4FiveWhyId], references: [id])
  ishikawa   IshikawaAnalysis? @relation("EightDIshikawa", fields: [d4IshikawaId], references: [id])

  @@index([siteId])
  @@index([status])
  @@map("eight_d_reports")
}

// ===== SAFETY INCIDENTS (ISO 45001) =====

model SafetyIncident {
  id            String  @id @default(cuid())
  siteId        String
  reporterId    String
  workstationId String?

  // Classification
  type     String // injury | near_miss | property_damage | environmental | first_aid
  severity String   @default("minor") // minor | moderate | serious | critical
  outcome  String   @default("no_injury") // no_injury | first_aid | medical_treatment | restricted_work | lost_time | fatality
  date     DateTime
  time     String? // "14:30"
  location String // area/zone description

  // Details
  title             String
  description       String
  injuredPerson     String?
  injuryType        String? // laceration | burn | crush | strain | chemical_exposure | fall | other
  bodyPart          String? // hand | arm | leg | head | back | eye | other
  treatmentGiven    String?
  daysLost          Int     @default(0)
  potentialSeverity String? // for near-misses: what COULD have happened
  isOshaRecordable  Boolean @default(false)

  // Investigation
  immediateAction    String?
  witnessNames       String? // JSON array
  status             String    @default("reported")
  // reported | investigating | root_cause_identified | corrective_action | verification | closed
  investigatorId     String?
  investigationDate  DateTime?
  investigationNotes String?

  // RCA links
  fiveWhyId      String?
  ishikawaId     String?
  eightDReportId String?

  photoUrl  String?
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  site         Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reporter     User               @relation("SafetyReporter", fields: [reporterId], references: [id])
  workstation  Workstation?       @relation(fields: [workstationId], references: [id])
  investigator User?              @relation("SafetyInvestigator", fields: [investigatorId], references: [id])
  attachments  SafetyAttachment[]

  @@index([siteId])
  @@index([siteId, type, date])
  @@index([severity, date])
  @@map("safety_incidents")
}

model SafetyAttachment {
  id           String   @id @default(cuid())
  incidentId   String
  fileName     String
  fileUrl      String
  uploadedById String
  createdAt    DateTime @default(now())

  incident SafetyIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("safety_attachments")
}

// ===== V5: ACTION TRACKER =====

model Action {
  id          String    @id @default(cuid())
  siteId      String
  title       String
  description String?
  category    String    @default("delivery") // safety | quality | delivery | cost | people
  priority    String    @default("medium") // low | medium | high | critical
  status      String    @default("open") // open | in_progress | completed | overdue | cancelled
  source      String // gemba | ncr | kaizen | safety | five_s | maintenance | tier_meeting | manual
  sourceId    String? // ID of the source record
  assigneeId  String
  createdById String
  dueDate     DateTime
  completedAt DateTime?
  notes       String?
  tierLevel   Int? // 1=team, 2=area, 3=plant — for escalation
  escalatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site      Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assignee  User @relation("ActionAssignee", fields: [assigneeId], references: [id])
  createdBy User @relation("ActionCreator", fields: [createdById], references: [id])

  @@index([siteId])
  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
  @@map("actions")
}

// ===== V5: NOTIFICATIONS =====

model Notification {
  id         String    @id @default(cuid())
  siteId     String
  userId     String // recipient
  type       String // breakdown | ncr | safety | overdue_action | oee_alert | tier_escalation
  title      String
  message    String
  sourceType String? // action | incident | ncr | workstation
  sourceId   String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([siteId])
  @@map("notifications")
}

// ===== V5: TIER MEETINGS (SQDCP) =====

model TierMeeting {
  id        String    @id @default(cuid())
  siteId    String
  tier      Int // 1=team, 2=area, 3=plant
  date      String // "2026-04-01"
  shift     String? // morning | afternoon | night
  leaderId  String
  attendees String? // comma-separated user IDs or JSON
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  status    String    @default("in_progress") // in_progress | completed
  notes     String?
  createdAt DateTime  @default(now())

  site   Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  leader User              @relation("TierMeetingLeader", fields: [leaderId], references: [id])
  items  TierMeetingItem[]

  @@index([siteId, date])
  @@map("tier_meetings")
}

model TierMeetingItem {
  id        String  @id @default(cuid())
  meetingId String
  category  String // safety | quality | delivery | cost | people
  status    String  @default("green") // green | yellow | red
  metric    String? // KPI name
  value     String? // KPI value
  target    String? // KPI target
  comment   String?
  actionId  String? // link to action if escalated
  escalated Boolean @default(false)

  meeting TierMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("tier_meeting_items")
}

// ===== V5: A3 PROBLEM SOLVING =====

model A3Report {
  id                 String    @id @default(cuid())
  siteId             String
  title              String
  ownerId            String
  sponsorId          String?
  status             String    @default("draft") // draft | in_progress | review | completed | closed
  background         String? // Why is this important?
  currentCondition   String? // What is happening now?
  targetCondition    String? // What should be happening?
  gapAnalysis        String? // What is the gap?
  rootCauseAnalysis  String? // Why does the gap exist?
  fiveWhyId          String?
  ishikawaId         String?
  countermeasures    String? // What will we do?
  implementationPlan String? // How, who, when?
  confirmationMethod String? // How will we verify?
  followUpDate       DateTime?
  followUpNotes      String?
  categoryTag        String? // mechanical | procedural | etc.
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  site    Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  owner   User  @relation("A3Owner", fields: [ownerId], references: [id])
  sponsor User? @relation("A3Sponsor", fields: [sponsorId], references: [id])

  @@index([siteId])
  @@map("a3_reports")
}

// ===== V5: SKILLS MATRIX =====

model Skill {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  category    String   @default("technical") // technical | safety | quality | leadership | process
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userSkills UserSkill[]

  @@unique([siteId, name])
  @@map("skills")
}

model UserSkill {
  id            String    @id @default(cuid())
  userId        String
  skillId       String
  level         Int       @default(0) // 0=none, 1=learning, 2=competent, 3=proficient, 4=trainer
  certifiedDate DateTime?
  expiryDate    DateTime?
  assessedById  String?
  notes         String?
  updatedAt     DateTime  @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill      Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  assessedBy User? @relation("SkillAssessor", fields: [assessedById], references: [id])

  @@unique([userId, skillId])
  @@map("user_skills")
}

// ===== V5: SMED (CHANGEOVER ANALYSIS) =====

model SmedAnalysis {
  id              String    @id @default(cuid())
  siteId          String
  workstationId   String
  title           String
  productFrom     String?
  productTo       String?
  analystId       String
  status          String    @default("recording") // recording | analyzing | improved | verified
  baselineMinutes Int? // original changeover time
  targetMinutes   Int? // target after improvement
  actualMinutes   Int? // achieved after improvement
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  site        Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workstation Workstation    @relation(fields: [workstationId], references: [id])
  analyst     User           @relation("SmedAnalyst", fields: [analystId], references: [id])
  activities  SmedActivity[]

  @@index([siteId])
  @@map("smed_analyses")
}

model SmedActivity {
  id              String  @id @default(cuid())
  analysisId      String
  sequence        Int
  description     String
  type            String  @default("internal") // internal | external
  durationSeconds Int
  canConvert      Boolean @default(false) // can this internal activity become external?
  convertedTo     String? @default("internal") // what it became after improvement
  improvement     String? // how it was improved

  analysis SmedAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("smed_activities")
}

// ===== V5: SITE TOOL CONFIGURATION =====

model SiteToolConfig {
  id        String  @id @default(cuid())
  siteId    String
  toolSlug  String  // e.g. "five-s", "kaizen", "smed", "gemba", "safety", etc.
  isEnabled Boolean @default(true)
  minRole   String  @default("operator") // minimum role to access this tool at this site

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, toolSlug])
  @@map("site_tool_configs")
}

// ===== V5: ESCALATION ENGINE (Digital Andon) =====

model EscalationRule {
  id               String   @id @default(cuid())
  siteId           String
  name             String
  isActive         Boolean  @default(true)
  triggerType      String   // breakdown, safety_incident, ncr_critical, action_overdue
  conditionMinutes Int      @default(10)
  notifyGroup      String   // permission feature group to notify
  notifyLevel      String   // minimum permission level
  escalationTier   Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, name])
  @@map("escalation_rules")
}

model EscalationLog {
  id         String   @id @default(cuid())
  ruleId     String
  sourceType String
  sourceId   String
  notifiedAt DateTime @default(now())

  @@unique([ruleId, sourceId])
  @@map("escalation_logs")
}
